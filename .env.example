# ============================================================
# SigEnergy Optimizer — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ── Home Assistant ─────────────────────────────────────────────────────────
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# ── Polling ────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=30

# ── Notifications ──────────────────────────────────────────────────────────
# Leave blank to disable. Format: notify.service_name
NOTIFICATION_SERVICE=
NOTIFY_DAILY_SUMMARY=true
DAILY_SUMMARY_TIME=23:55
NOTIFY_MORNING_SUMMARY=true
MORNING_SUMMARY_TIME=07:30

# ── EMS Entity IDs ─────────────────────────────────────────────────────────
HA_CONTROL_SWITCH=switch.sigen_plant_remote_ems_controled_by_home_assistant
EMS_MODE_SELECT=select.sigen_plant_remote_ems_control_mode
GRID_EXPORT_LIMIT=number.sigen_plant_grid_export_limitation
GRID_IMPORT_LIMIT=number.sigen_plant_grid_import_limitation
PV_MAX_POWER_LIMIT=number.sigen_plant_pv_max_power_limit
ESS_MAX_CHARGING_LIMIT=number.sigen_plant_ess_max_charging_limit
ESS_MAX_DISCHARGING_LIMIT=number.sigen_plant_ess_max_discharging_limit

# ── SigEnergy Sensors ──────────────────────────────────────────────────────
PV_POWER_SENSOR=sensor.sigen_plant_pv_power
CONSUMED_POWER_SENSOR=sensor.sigen_plant_consumed_power
GRID_IMPORT_POWER_SENSOR=sensor.sigen_plant_grid_import_power
GRID_EXPORT_POWER_SENSOR=sensor.sigen_plant_grid_export_power
# Optional direct battery power sensor (preferred for UI charge/discharge rate)
# Positive is treated as charging by default; set BATTERY_POWER_SENSOR_INVERT=true if your sensor polarity is opposite.
BATTERY_POWER_SENSOR=sensor.sigen_plant_battery_power
BATTERY_POWER_SENSOR_INVERT=false
BATTERY_SOC_SENSOR=sensor.sigen_plant_battery_state_of_charge
RATED_CAPACITY_SENSOR=sensor.sigen_plant_rated_energy_capacity
AVAILABLE_DISCHARGE_SENSOR=sensor.sigen_plant_available_max_discharging_capacity
ESS_RATED_DISCHARGE_POWER_SENSOR=sensor.sigen_inverter_ess_rated_discharge_power
ESS_RATED_CHARGE_POWER_SENSOR=sensor.sigen_plant_ess_rated_charging_power
SUN_ENTITY=sun.sun
DAILY_EXPORT_ENERGY=sensor.sigen_plant_daily_grid_export_energy
DAILY_IMPORT_ENERGY=sensor.sigen_plant_daily_grid_import_energy
DAILY_LOAD_ENERGY=sensor.sigen_plant_daily_load_consumption
DAILY_BATTERY_CHARGE_ENERGY=sensor.sigen_plant_daily_battery_charge_energy
DAILY_BATTERY_DISCHARGE_ENERGY=sensor.sigen_plant_daily_battery_discharge_energy
DAILY_PV_ENERGY=sensor.sigen_plant_daily_pv_generation

# ── Price / Amber Sensors ──────────────────────────────────────────────────
PRICE_SENSOR=sensor.amber_general_price
FEEDIN_SENSOR=sensor.amber_feed_in_price
FEEDIN_FORECAST_SENSOR=sensor.amber_feed_in_price_detailed
DEMAND_WINDOW_SENSOR=binary_sensor.amber_demand_window
PRICE_SPIKE_SENSOR=binary_sensor.amber_price_spike
PRICE_FORECAST_SENSOR=sensor.amber_general_forecast
PRICE_FORECAST_ATTRIBUTE=forecasts
PRICE_FORECAST_VALUE_KEY=per_kwh
PRICE_FORECAST_TIME_KEY=start_time
PRICE_MULTIPLIER=100.0
FEEDIN_FORECAST_ATTRIBUTE=forecasts
FEEDIN_FORECAST_VALUE_KEY=per_kwh

# ── Solcast Sensors ────────────────────────────────────────────────────────
FORECAST_REMAINING_SENSOR=sensor.solcast_pv_forecast_forecast_remaining_today
FORECAST_TODAY_SENSOR=sensor.solcast_pv_forecast_forecast_today
FORECAST_TOMORROW_SENSOR=sensor.solcast_pv_forecast_forecast_tomorrow
SOLAR_POWER_NOW_SENSOR=sensor.solcast_pv_forecast_power_now
PRODUCTIVE_SOLAR_THRESHOLD_KW=1.0
SOLCAST_FORECAST_PERIOD_HOURS=0.5

# ── HA Helpers ─────────────────────────────────────────────────────────────
AUTOMATED_EXPORT_FLAG=input_boolean.sigenergy_automated_export
EXPORT_SESSION_START=input_number.sigenergy_export_session_start_kwh
IMPORT_SESSION_START=input_number.sigenergy_import_session_start_kwh
LAST_EXPORT_NOTIFICATION=input_text.sigenergy_last_export_notification
LAST_IMPORT_NOTIFICATION=input_text.sigenergy_last_import_notification
REASON_TEXT_HELPER=input_text.sigenergy_reason
MIN_SOC_TO_SUNRISE_HELPER=input_number.battery_min_soc_to_last_till_sunrise
SIGENERGY_MODE_SELECT=input_select.sigenergy_mode

# ── Export Pricing ─────────────────────────────────────────────────────────
EXPORT_THRESHOLD_LOW=0.10
EXPORT_THRESHOLD_MEDIUM=0.20
EXPORT_THRESHOLD_HIGH=1.00
EXPORT_LIMIT_LOW=5.0
EXPORT_LIMIT_MEDIUM=12.0
EXPORT_LIMIT_HIGH=25.0
EXPORT_SPIKE_THRESHOLD=0.0
EXPORT_SPIKE_FULL_POWER=false
ALLOW_LOW_MEDIUM_EXPORT_POSITIVE_FIT=false
ALLOW_POSITIVE_FIT_BATTERY_DISCHARGING=false

# ── Import Pricing ─────────────────────────────────────────────────────────
IMPORT_THRESHOLD_LOW=0.0
IMPORT_THRESHOLD_MEDIUM=-0.15
IMPORT_THRESHOLD_HIGH=-0.30
IMPORT_LIMIT_LOW=30.0
IMPORT_LIMIT_MEDIUM=30.0
IMPORT_LIMIT_HIGH=30.0

# ── SoC Floors & Reserves ─────────────────────────────────────────────────
MIN_EXPORT_TARGET_SOC=90.0
MIN_SOC_FLOOR=20.0
NIGHT_RESERVE_SOC=30.0
NIGHT_RESERVE_BUFFER=10.0
MAX_BATTERY_SOC=50.0
SUNRISE_RESERVE_SOC=10.0
SUNRISE_SAFETY_FACTOR=1.0
SUNRISE_BUFFER_PERCENT=0.0
SUNRISE_EXPORT_RELAX_PERCENT=12.0

# ── Evening Boost ─────────────────────────────────────────────────────────
EVENING_BOOST_ENABLED=true
EVENING_AGGRESSIVE_FLOOR=35.0

# ── Cheap Import Top-up ────────────────────────────────────────────────────
MAX_PRICE_THRESHOLD=0.015
TARGET_BATTERY_CHARGE=2.0
CAP_TOTAL_IMPORT=30.0
PV_MAX_POWER_NORMAL=25.0
DAYTIME_TOPUP_MAX_SOC=50.0

# ── Forecast Holdoff ──────────────────────────────────────────────────────
STANDBY_HOLDOFF_ENABLED=true
SLOW_CHARGE_HOLDOFF=false
SLOW_CHARGE_LIMIT_KW=2.0
PV_FORECAST_HOLDOFF_KWH=120.0
NEGATIVE_PRICE_FORECAST_LOOKAHEAD_HOURS=12
STANDBY_HOLDOFF_END_TIME=11:00

# ── Morning Slow Charge ────────────────────────────────────────────────────
MORNING_SLOW_CHARGE_ENABLED=false
MORNING_SLOW_CHARGE_UNTIL=11:00
MORNING_SLOW_CHARGE_RATE_KW=2.0
MORNING_SLOW_CHARGE_MIN_FEEDIN_PRICE=0.0
MORNING_SLOW_CHARGE_BASE_LOAD_KW=0.5
MORNING_SLOW_CHARGE_SUNSET_CUTOFF=1.0

# ── Morning Dump ──────────────────────────────────────────────────────────
MORNING_DUMP_ENABLED=false
MORNING_DUMP_HOURS_BEFORE_SUNRISE=2.0

# ── Battery Full Safeguard ────────────────────────────────────────────────
BATTERY_FULL_SAFEGUARD_ENABLED=true
BATTERY_FULL_HOURS_BEFORE_SUNSET=2.0
BATTERY_FULL_FORECAST_MULTIPLIER=0.8

# ── Anti-flap Hysteresis ──────────────────────────────────────────────────
SOC_HYSTERESIS=2.0
MIN_CHANGE_THRESHOLD=0.1
MIN_GRID_TRANSFER_KW=0.5
EXPORT_HYSTERESIS_PERCENT=0.8
PRICE_HYSTERESIS=0.01

# ── Forecast Safety ───────────────────────────────────────────────────────
FORECAST_SAFETY_CHARGING=1.25
FORECAST_SAFETY_EXPORT=1.1

# ── Export Scheduling ─────────────────────────────────────────────────────
EXPORT_SOC_SPAN_DAY=20.0
EXPORT_DISCHARGE_WINDOW_HOURS=3.0
SUN_ELEVATION_EVENING_THRESHOLD=10.0
SUNSET_EXPORT_GRACE_HOURS=2.0
EVENING_MODE_HOURS_BEFORE_SUNSET=1.0
EXPORT_GUARD_RELAX_SOC=90.0

# ── Solar Surplus Bypass ─────────────────────────────────────────────────
SOLAR_SURPLUS_BYPASS_ENABLED=true
SOLAR_SURPLUS_START_MULTIPLIER=2.0
SOLAR_SURPLUS_STOP_MULTIPLIER=1.25
SOLAR_SURPLUS_MIN_PV_MARGIN=0.5
